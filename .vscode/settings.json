{
    "terminal.integrated.defaultProfile.linux": "Zephyr IDE Terminal",
    "terminal.integrated.env.linux": {
        "WEST_TOPDIR": "/workdir",
        "ZEPHYR_BASE": "/workdir/external/zephyr",
        "PATH": "/opt/zephyr-venv/bin:${env:PATH}"
    },
    "zephyr-ide.boardRoots": [
        "${workspaceFolder}/boards",
        "${env:ZEPHYR_BASE}/boards"
    ],
    "zephyr-ide.defaultBoard": "clicker4_stm32f7",
    "zephyr-ide.venv-folder": "/opt/zephyr-venv",
    "python.defaultInterpreterPath": "/opt/zephyr-venv/bin/python",
    "terminal.integrated.cwd": "/workdir",
    "C_Cpp.default.compileCommands": "${workspaceFolder}/.vscode/compile_commands.json",
    "cmake.configureOnOpen": false,
    "files.associations": {
        "future": "c",
        "stdio.h": "c",
        "string.h": "c",
        "imu.h": "c",
        "stdlib.h": "c",
        "pwm.h": "c",
        "regex": "c",
        "pwm_actuator.h": "c",
        "rclc.h": "c",
        "watchdog.h": "c",
        "log.h": "c",
        "int8.h": "c",
        "bool.h": "c",
        "socket.h": "c",
        "poll.h": "c",
        "int32.h": "c",
        "twist.h": "c",
        "icm42x70.h": "c",
        "sensor.h": "c",
        "kernel.h": "c",
        "util.h": "c",
        "ina3221_sensor.h": "c"
    },
    "terminal.integrated.defaultProfile.osx": "Zephyr IDE Terminal"
}
